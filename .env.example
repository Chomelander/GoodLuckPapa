# 环境变量示例（复制为 .env 并修改）

# ═════════════════════════════════════════════════════
# Bun 服务器配置
# ═════════════════════════════════════════════════════

# JWT 签名密钥（强随机字符串，勿泄露）
JWT_SECRET=your-super-secret-jwt-key-change-this

# PIN 码（访问 PWA 的密码，建议修改）
ACCESS_PIN=1234

# SQLite 数据库路径（Docker Volume 挂载）
DATABASE_PATH=/data/sqlite.db

# Bun 服务器监听端口
PORT=8080

# ═════════════════════════════════════════════════════
# Docker Compose 配置
# ═════════════════════════════════════════════════════

# NAS 上的数据目录（修改为你的实际路径）
DATA_PATH=/mnt/nas/qiqi-data

# ═════════════════════════════════════════════════════
# Nginx 配置（HTTPS）
# ═════════════════════════════════════════════════════

# 如果使用 HTTPS，配置以下：
# NGINX_CERT_PATH=/path/to/cert.pem
# NGINX_KEY_PATH=/path/to/key.pem
# NGINX_SERVER_NAME=myqiqi.ugnas.com

# ═════════════════════════════════════════════════════
# 生成强密钥的命令
# ═════════════════════════════════════════════════════

# JWT_SECRET（64 字符随机字符串）:
# openssl rand -hex 32

# 自签名证书（如果需要 HTTPS）:
# openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -days 365 -nodes
